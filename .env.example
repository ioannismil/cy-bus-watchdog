# Cyprus Bus Tracker - Environment Variables
# Copy this file to .env and adjust values as needed.

# GTFS-RT protobuf feed URL
GTFS_RT_URL=http://20.19.98.194:8328/Api/api/gtfs-realtime

# Path to stops CSV file (default: data/stops.csv relative to project root)
# STOPS_FILE=data/stops.csv

# Vehicle cache duration in seconds
CACHE_TTL=10

# Server port
PORT=8080
